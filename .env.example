# ─── PayU Configuration ───────────────────────────────────────────────────────
# Switch between test/live by setting PAYU_ENV
# test  → uses PAYU_TEST_KEY + PAYU_TEST_SALT  → https://test.payu.in
# live  → uses PAYU_LIVE_KEY + PAYU_LIVE_SALT  → https://secure.payu.in

PAYU_ENV=test

PAYU_TEST_KEY=your_test_merchant_key
PAYU_TEST_SALT=your_test_salt

PAYU_LIVE_KEY=your_live_merchant_key
PAYU_LIVE_SALT=your_live_salt

# ─── Public plan IDs (used in Pricing component) ─────────────────────────────
NEXT_PUBLIC_PAYU_PLAN_PRO_MONTHLY=pro_monthly
NEXT_PUBLIC_PAYU_PLAN_PRO_ANNUAL=pro_annual
NEXT_PUBLIC_PAYU_PLAN_GROWTH_MONTHLY=growth_monthly
NEXT_PUBLIC_PAYU_PLAN_GROWTH_ANNUAL=growth_annual

# ─── App base URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
