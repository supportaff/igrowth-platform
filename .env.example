# ─── PayU ─────────────────────────────────────────────────────────────────────────────
#
# Variable NAMES are always PAYU_KEY and PAYU_SALT — they never change.
# To switch between test and live:
#   1. Change PAYU_ENV from "test" to "live"
#   2. Replace the VALUES of PAYU_KEY and PAYU_SALT with your live credentials
#
# Test endpoint  : https://test.payu.in/_payment
# Live endpoint  : https://secure.payu.in/_payment
# (The code picks the right URL automatically based on PAYU_ENV)

PAYU_ENV=test                  # change to: live
PAYU_KEY=your_merchant_key     # paste test key here; swap to live key when going live
PAYU_SALT=your_merchant_salt   # paste test salt here; swap to live salt when going live

# ─── App ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Supabase ───────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
